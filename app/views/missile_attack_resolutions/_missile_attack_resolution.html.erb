<% if missile_attack_resolution.missile_attack.unresolved? %>
  <%= form_with model: [missile_attack_resolution.missile_attack, missile_attack_resolution] do |f| %>
    <%= f.label :roll, t(".attack_roll", combatant: f.object.missile_attack.combatant_name) %>
    <%= f.text_field :roll %>
    <%= f.submit %>
  <% end %>
<% else %>
  <%= t ".result", combatant: missile_attack_resolution.missile_attack.combatant_name, result: missile_attack_resolution.missile_attack.actionable.result %>
  <%= t ".application", target: missile_attack_resolution.missile_attack.actionable.target.name, hits: missile_attack_resolution.missile_attack.actionable.target.combatable.hits %>
<% end %>
